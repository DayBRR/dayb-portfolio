---
import MainLayout from '../layouts/MainLayout.astro';
import IdeShell from '../components/IdeShell.astro';
import HeroSection from '../components/HeroSection.astro';
import FocusSection from '../components/FocusSection.astro';
import SkillsSection from '../components/SkillsSection.astro';
import StackSection from '../components/StackSection.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import TimelineSection from '../components/TimelineSection.astro';
import ProjectModal from '../components/ProjectModal.astro';
import { featuredTech, focusHighlights, profile, projects, skills, stackTecnology, timeline } from '../data/portfolio';
import { fade } from 'astro:transitions';

const codeSnippet = [
  'class BackendEngineer {',
  "  name = 'David Ruiz Requejo';",
  "  role = 'Backend Analyst Programmer';",
  '',
  "  stack = ['Java', 'Oracle', 'Angular'];",
  "  interests = ['Automation', 'Cloud', 'Security'];",
  '',
  '  build() {',
  "    return 'scalable enterprise systems';",
  '  }',
  '}'
] as const;

const sections: Array<{
  id: string;
  nav: { es: string; en: string };
  active: boolean;
  Component: any;
  props: Record<string, unknown>;
}> = [
  {
    id: 'home',
    nav: { es: 'index.ts', en: 'index.ts' },
    active: true,
    Component: HeroSection,
    props: { profile, featuredTech, codeSnippet }
  },
  {
    id: 'focus',
    nav: { es: 'focus.md', en: 'focus.md' },
    active: true,
    Component: FocusSection,
    props: { highlights: focusHighlights }
  },
  {
    id: 'skills',
    nav: { es: 'skills.json', en: 'skills.json' },
    active: false,
    Component: SkillsSection,
    props: { skills }
  },
  {
    id: 'stack',
    nav: { es: 'stack.yml', en: 'stack.yml' },
    active: true,
    Component: StackSection,
    props: { stackTecnology }
  },
  {
    id: 'projects',
    nav: { es: 'projects.db', en: 'projects.db' },
    active: true,
    Component: ProjectsSection,
    props: { projects }
  },
  {
    id: 'timeline',
    nav: { es: 'timeline.log', en: 'timeline.log' },
    active: true,
    Component: TimelineSection,
    props: { timeline }
  }
] ;

const activeSections = sections.filter((section) => section.active);
---

<MainLayout title="Portfolio Backend | IntelliJ Style">
  <IdeShell
    profileName={profile.name}
    navItems={activeSections.map(({ id, nav }) => ({ id, label: nav }))}
  >
    {activeSections.map((section) => {
      const Section = section.Component;
      return <Section {...section.props} />;
    })}
  </IdeShell>
  <ProjectModal />
</MainLayout>
