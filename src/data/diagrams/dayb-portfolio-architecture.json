{
  "$schema": "./diagram.schema.json",
  "key": "dayb-portfolio-architecture",
  "header": {
    "eyebrow": {
      "es": "Arquitectura del portfolio",
      "en": "Portfolio architecture"
    },
    "title": {
      "es": "DayB Portfolio",
      "en": "DayB Portfolio"
    },
    "subtitle": {
      "es": "Sitio estatico en Astro con UI estilo IDE, datos tipados y despliegue en VPS con Docker.",
      "en": "Static Astro site with an IDE-style UI, typed data, and Docker-based VPS deployment."
    },
    "tone": "accent"
  },
  "defaults": {
    "headerTone": "accent",
    "nodeTone": "neutral",
    "connectorTone": "accent",
    "groupTone": "accent",
    "branchTone": "accent",
    "glow": {
      "fromTone": "accent",
      "toTone": "purple"
    },
    "node": {
      "width": "min(340px, 100%)",
      "padding": "16px",
      "radius": "12px",
      "titleColor": "var(--ide-text)",
      "subtitleColor": "var(--ide-muted)",
      "iconBoxSize": "40px",
      "iconRadius": "10px",
      "iconMarginBottom": "8px",
      "textAlign": "center"
    },
    "line": {
      "length": "16px",
      "thickness": "2px",
      "from": "color-mix(in oklab, var(--ide-border), var(--ide-accent) 40%)",
      "to": "color-mix(in oklab, var(--ide-border), var(--ide-accent) 10%)",
      "radius": "999px"
    },
    "pill": {
      "borderColor": "var(--ide-border)",
      "background": "var(--ide-panel-soft)",
      "textColor": "var(--ide-muted)",
      "letterSpacing": "0.12em",
      "padding": "4px 12px"
    },
    "group": {
      "borderColor": "color-mix(in oklab, var(--ide-border), var(--ide-accent) 18%)",
      "background": "color-mix(in oklab, var(--ide-panel), transparent 30%)",
      "titleColor": "var(--ide-text)",
      "itemBorderColor": "color-mix(in oklab, var(--ide-border), var(--ide-accent) 20%)",
      "itemBackground": "color-mix(in oklab, var(--ide-panel), var(--ide-bg) 35%)",
      "itemTextColor": "var(--ide-muted)",
      "padding": "12px 12px 10px",
      "radius": "12px"
    },
    "subgroup": {
      "borderColor": "color-mix(in oklab, var(--ide-border), var(--ide-accent) 18%)",
      "background": "color-mix(in oklab, var(--ide-panel), var(--ide-bg) 24%)",
      "titleColor": "var(--ide-text)",
      "itemBorderColor": "color-mix(in oklab, var(--ide-border), var(--ide-accent) 16%)",
      "itemBackground": "color-mix(in oklab, var(--ide-panel), var(--ide-bg) 42%)",
      "itemTextColor": "var(--ide-muted)",
      "padding": "10px",
      "radius": "10px"
    },
    "branchColumns": {
      "width": "min(920px, 100%)",
      "gap": "16px",
      "count": 3,
      "junctionInsetStart": "8%",
      "junctionInsetEnd": "8%",
      "junctionTop": "-8px",
      "mobileHeight": "10px"
    },
    "subgroupLayout": {
      "count": 1,
      "gap": "10px",
      "marginTop": "6px",
      "paddingTop": "14px",
      "connectorLength": "12px",
      "junctionInsetStart": "10%",
      "junctionInsetEnd": "10%",
      "junctionTop": "0",
      "mobileHeight": "10px"
    }
  },
  "sections": [
    {
      "type": "node",
      "id": "browser",
      "icon": "browser",
      "title": {
        "es": "Navegador",
        "en": "Browser"
      },
      "subtitle": {
        "es": "Portfolio bilingue con tema y modal de proyectos",
        "en": "Bilingual portfolio with theming and project modal"
      },
      "tone": "accent",
      "strong": true,
      "glow": true
    },
    {
      "type": "connector",
      "id": "transport",
      "label": {
        "es": "HTTPS / CSS / JS",
        "en": "HTTPS / CSS / JS"
      },
      "tone": "info"
    },
    {
      "type": "node",
      "id": "edge",
      "icon": "delivery",
      "title": {
        "es": "VPS + Nginx",
        "en": "VPS + Nginx"
      },
      "subtitle": {
        "es": "Contenedor Docker sirviendo dist/",
        "en": "Docker container serving dist/"
      }
    },
    {
      "type": "connector",
      "id": "deploy",
      "label": {
        "es": "BUILD / DEPLOY",
        "en": "BUILD / DEPLOY"
      },
      "tone": "success"
    },
    {
      "type": "node",
      "id": "astro-build",
      "icon": "astro",
      "title": {
        "es": "Astro Static Build",
        "en": "Astro Static Build"
      },
      "subtitle": {
        "es": "SSG + Tailwind + salida estatica",
        "en": "SSG + Tailwind + static output"
      },
      "tone": "purple"
    },
    {
      "type": "branch",
      "id": "architecture",
      "groups": [
        {
          "id": "ide-ui",
          "icon": "layoutGrid",
          "title": {
            "es": "IDE UI Shell",
            "en": "IDE UI Shell"
          },
          "tone": "accent",
          "items": [],
          "subgroupLayout": {
            "count": 1,
            "gap": "10px",
            "paddingTop": "14px",
            "connectorLength": "12px"
          },
          "subgroupAppearance": {
            "borderColor": "color-mix(in oklab, var(--ide-border), var(--ide-accent) 22%)",
            "background": "color-mix(in oklab, var(--ide-panel), var(--ide-bg) 22%)"
          },
          "subgroups": [
            {
              "id": "layout-shell",
              "title": {
                "es": "MainLayout + Shell",
                "en": "MainLayout + Shell"
              },
              "icon": "layoutGrid",
              "tone": "accent",
              "items": [
                {
                  "label": {
                    "es": "SEO, canonical y Open Graph",
                    "en": "SEO, canonical and Open Graph"
                  },
                  "tone": "accent"
                },
                {
                  "label": {
                    "es": "Header, sidebar y layout tipo editor",
                    "en": "Header, sidebar and editor-style layout"
                  },
                  "tone": "info"
                }
              ]
            },
            {
              "id": "sections-modal",
              "title": {
                "es": "Sections + Modal",
                "en": "Sections + Modal"
              },
              "icon": "astro",
              "tone": "cyan",
              "items": [
                {
                  "label": {
                    "es": "Hero, focus, skills, stack, projects y timeline",
                    "en": "Hero, focus, skills, stack, projects and timeline"
                  },
                  "tone": "cyan"
                },
                {
                  "label": {
                    "es": "ProjectModal con dialog nativo",
                    "en": "ProjectModal with native dialog"
                  },
                  "tone": "accent"
                }
              ]
            }
          ]
        },
        {
          "id": "client-runtime",
          "icon": "globe",
          "title": {
            "es": "Client Runtime",
            "en": "Client Runtime"
          },
          "tone": "purple",
          "items": [
            {
              "label": {
                "es": "i18n por URL, cookie y localStorage",
                "en": "i18n via URL, cookie and localStorage"
              },
              "tone": "purple"
            },
            {
              "label": {
                "es": "Theme toggle persistente",
                "en": "Persistent theme toggle"
              },
              "tone": "success"
            },
            {
              "label": {
                "es": "Scripts inline para estado, modal y microinteracciones",
                "en": "Inline scripts for state, modal and micro-interactions"
              },
              "tone": "info"
            }
          ]
        },
        {
          "id": "content-config",
          "icon": "folder",
          "title": {
            "es": "Contenido y Configuracion",
            "en": "Content and Configuration"
          },
          "tone": "warn",
          "items": [
            {
              "label": {
                "es": "src/data/portfolio.ts como fuente tipada",
                "en": "src/data/portfolio.ts as typed source"
              },
              "tone": "warn"
            },
            {
              "label": {
                "es": "projectStatus, diagram configs e iconos",
                "en": "projectStatus, diagram configs and icons"
              },
              "tone": "info"
            },
            {
              "label": {
                "es": "astro.config, Tailwind y assets en public/",
                "en": "astro.config, Tailwind and public/ assets"
              },
              "tone": "success"
            }
          ]
        }
      ],
      "bottomLine": true
    },
    {
      "type": "node",
      "id": "delivery-pipeline",
      "icon": "gitBranch",
      "title": {
        "es": "GitHub Actions + Docker",
        "en": "GitHub Actions + Docker"
      },
      "subtitle": {
        "es": "Push a main, runner self-hosted y despliegue en VPS",
        "en": "Push to main, self-hosted runner and VPS deployment"
      },
      "hoverTone": "danger"
    }
  ]
}
