---
type LocalizedText = {
  es: string;
  en: string;
};

type DiagramCard = {
  nodeClass: string;
  iconWrapperClass: string;
  title: LocalizedText;
  subtitle: LocalizedText;
  icon: string;
  glowClass?: string;
};

type DiagramGroup = {
  boxClass: string;
  iconClass: string;
  title: LocalizedText;
  icon: string;
  items: readonly {
    dotClass: string;
    label: LocalizedText;
  }[];
};

const i18nAttrs = (text: LocalizedText) => ({
  'data-i18n-es': text.es,
  'data-i18n-en': text.en
});

const header = {
  eyebrow: { es: 'Arquitectura del sistema', en: 'System architecture' },
  title: { es: 'Infraestructura del Portfolio', en: 'Portfolio Infrastructure' },
  subtitle: {
    es: 'Entrega estatica basada en Astro y Tailwind CSS.',
    en: 'Static delivery built with Astro and Tailwind CSS.'
  }
} as const;

const topCards: readonly DiagramCard[] = [
  {
    nodeClass: 'diagram-node diagram-node-strong group relative',
    glowClass:
      'absolute -inset-0.5 rounded-xl bg-gradient-to-r from-ide-accent/20 to-ide-purple/20 opacity-0 blur transition duration-300 group-hover:opacity-100',
    iconWrapperClass: 'border border-ide-accent/30 bg-ide-accent-soft text-ide-accent',
    title: { es: 'Navegador', en: 'Browser' },
    subtitle: { es: 'Usuario final (Client-side)', en: 'End user (Client-side)' },
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>`
  },
  {
    nodeClass: 'diagram-node',
    iconWrapperClass: 'border border-ide-border bg-ide-panel-soft text-ide-muted',
    title: { es: 'Cloud Hosting / CDN', en: 'Cloud Hosting / CDN' },
    subtitle: { es: 'Edge Network & Static Assets', en: 'Edge Network & Static Assets' },
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19l4.5-4.5L17.5 10"></path><path d="M6.5 5l-4.5 4.5L6.5 14"></path><path d="M12 2v20"></path></svg>`
  },
  {
    nodeClass: 'diagram-node border-ide-purple/40 bg-ide-purple/5',
    iconWrapperClass: 'border border-ide-purple/30 bg-ide-purple/10 text-ide-purple',
    title: { es: 'Astro Build Pipeline', en: 'Astro Build Pipeline' },
    subtitle: { es: 'Static Site Generation (SSG)', en: 'Static Site Generation (SSG)' },
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"></path><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"></path><path d="M9 12H4s.5-1 1-4c2 0 3 .5 3 .5l2-2s.5.5 1 2c0 2-1 3.5-1 3.5z"></path><path d="M15 11l2 2"></path></svg>`
  }
] as const;

const groups: readonly DiagramGroup[] = [
  {
    boxClass: 'diagram-box group/box border-dashed transition-colors hover:border-ide-accent/40',
    iconClass: 'text-ide-accent',
    title: { es: 'Frontend Architecture', en: 'Frontend Architecture' },
    icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>`,
    items: [
      {
        dotClass: 'bg-ide-accent',
        label: { es: 'Astro Layouts & Componentes', en: 'Astro Layouts & Components' }
      },
      {
        dotClass: 'bg-ide-cyan',
        label: { es: 'Sistema de diseno Tailwind', en: 'Tailwind Design System' }
      },
      {
        dotClass: 'bg-ide-purple',
        label: { es: 'UI Interactiva (Islands)', en: 'Interactive UI (Islands)' }
      }
    ]
  },
  {
    boxClass: 'diagram-box group/box border-dashed transition-colors hover:border-ide-warn/40',
    iconClass: 'text-ide-warn',
    title: { es: 'Contenido & Logica', en: 'Content & Logic' },
    icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>`,
    items: [
      {
        dotClass: 'bg-ide-warn',
        label: { es: 'Modelos de datos TypeScript', en: 'TypeScript Data Models' }
      },
      {
        dotClass: 'bg-ide-info',
        label: { es: 'Estrategia i18n', en: 'i18n Strategy' }
      },
      {
        dotClass: 'bg-ide-success',
        label: { es: 'Assets Optimizados', en: 'Optimized Assets' }
      }
    ]
  }
] as const;

const gitCard: DiagramCard = {
  nodeClass: 'diagram-node group',
  iconWrapperClass:
    'border border-ide-border bg-ide-panel-soft text-ide-muted transition-colors group-hover:border-ide-danger/30 group-hover:text-ide-danger',
  title: { es: 'Repositorio Git', en: 'Git Repository' },
  subtitle: { es: 'Source Control & CI/CD', en: 'Source Control & CI/CD' },
  icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="18" r="3"></circle><circle cx="6" cy="6" r="3"></circle><circle cx="18" cy="6" r="3"></circle><path d="M18 9v2c0 1.1-.9 2-2 2H8c-1.1 0-2-.9-2-2V9"></path><path d="M12 13V21"></path></svg>`
};

const transportPill = {
  className: 'diagram-pill border-ide-info/30 bg-ide-info/10 text-ide-info',
  label: { es: 'HTTPS / WOFF2', en: 'HTTPS / WOFF2' }
} as const;

const deployPill = {
  className: 'diagram-pill border-ide-success/30 bg-ide-success/10 text-ide-success',
  label: { es: 'DEPLOY', en: 'DEPLOY' }
} as const;
---

<div id="diagram-dayb-portfolio-architecture" class="diagram-canvas hidden" data-diagram-key="dayb-portfolio-architecture">
  <div class="mb-6 border-b border-ide-border/50 pb-4">
    <div class="diagram-header" {...i18nAttrs(header.eyebrow)}>{header.eyebrow.en}</div>
    <div class="diagram-title" {...i18nAttrs(header.title)}>{header.title.en}</div>
    <div class="diagram-subtitle mt-1" {...i18nAttrs(header.subtitle)}>{header.subtitle.en}</div>
  </div>

  <div class="diagram-flow">
    {
      topCards.map((card, index) => (
        <Fragment>
          <div class={card.nodeClass}>
            {card.glowClass ? <div class={card.glowClass}></div> : null}
            <div class="relative flex flex-col items-center">
              <div class={`mb-2 flex h-10 w-10 items-center justify-center rounded-lg ${card.iconWrapperClass}`}>
                <span class="inline-flex" aria-hidden="true" set:html={card.icon}></span>
              </div>
              <div class="diagram-node-title" {...i18nAttrs(card.title)}>{card.title.en}</div>
              <div class="diagram-node-sub" {...i18nAttrs(card.subtitle)}>{card.subtitle.en}</div>
            </div>
          </div>

          {
            index === 0 ? (
              <div class="diagram-connector-container flex flex-col items-center">
                <div class="diagram-connector"></div>
                <div class={transportPill.className} {...i18nAttrs(transportPill.label)}>{transportPill.label.en}</div>
                <div class="diagram-connector"></div>
              </div>
            ) : null
          }

          {
            index === 1 ? (
              <div class="diagram-connector-container flex flex-col items-center">
                <div class="diagram-connector"></div>
                <div class={deployPill.className} {...i18nAttrs(deployPill.label)}>{deployPill.label.en}</div>
                <div class="diagram-connector"></div>
              </div>
            ) : null
          }

          {index === 2 ? <div class="diagram-connector"></div> : null}
        </Fragment>
      ))
    }

    <div class="diagram-branch">
      <div class="diagram-branch-line"></div>
      <div class="diagram-columns">
        {
          groups.map((group) => (
            <div class={group.boxClass}>
              <div class="mb-2 flex items-center gap-2">
                <span class={`inline-flex ${group.iconClass}`} aria-hidden="true" set:html={group.icon}></span>
                <div class="diagram-box-title" {...i18nAttrs(group.title)}>{group.title.en}</div>
              </div>
              <div class="grid grid-cols-1 gap-2">
                {
                  group.items.map((item) => (
                    <div class="diagram-box-item flex items-center gap-2">
                      <span class={`h-1.5 w-1.5 rounded-full ${item.dotClass}`}></span>
                      <span {...i18nAttrs(item.label)}>{item.label.en}</span>
                    </div>
                  ))
                }
              </div>
            </div>
          ))
        }
      </div>
      <div class="diagram-branch-line"></div>
    </div>

    <div class="diagram-connector"></div>

    <div class={gitCard.nodeClass}>
      <div class="flex flex-col items-center">
        <div class={`mb-2 flex h-10 w-10 items-center justify-center rounded-lg ${gitCard.iconWrapperClass}`}>
          <span class="inline-flex" aria-hidden="true" set:html={gitCard.icon}></span>
        </div>
        <div class="diagram-node-title" {...i18nAttrs(gitCard.title)}>{gitCard.title.en}</div>
        <div class="diagram-node-sub" {...i18nAttrs(gitCard.subtitle)}>{gitCard.subtitle.en}</div>
      </div>
    </div>
  </div>
</div>
