---
import type { StackTecnologyGroup } from '../data/portfolio';
import { t, type Lang } from '../lib/i18n';

interface Props {
  stackTecnology: readonly StackTecnologyGroup[];
  lang: Lang;
}

const { stackTecnology, lang } = Astro.props;

const totalItems = stackTecnology.reduce((sum, group) => sum + group.items.length, 0);
const sectionTitle = { es: 'Stack Tecnológico', en: 'Technology Stack' };
const sectionCopy = {
  es: 'Tecnologías clave organizadas por dominio para construir productos backend robustos.',
  en: 'Key technologies grouped by domain to build robust backend products.'
};
const domainCount = { es: `${stackTecnology.length} dominios`, en: `${stackTecnology.length} domains` };
const itemCount = { es: `${totalItems} tecnologías`, en: `${totalItems} technologies` };

const groupToneStyle = (group: StackTecnologyGroup) => {
  switch (group.topic) {
    case 'quality':
      return '--tone: var(--ide-purple); --tone-soft: color-mix(in oklab, var(--ide-purple), transparent 84%);';
    case 'data':
      return '--tone: var(--ide-success); --tone-soft: color-mix(in oklab, var(--ide-success), transparent 84%);';
    case 'frontend':
      return '--tone: var(--ide-accent); --tone-soft: color-mix(in oklab, var(--ide-accent), transparent 84%);';
    case 'devops':
      return '--tone: var(--ide-danger); --tone-soft: color-mix(in oklab, var(--ide-danger), transparent 84%);';
    case 'backend':
    default:
      return '--tone: var(--ide-warn); --tone-soft: var(--ide-warn-soft);';
  }
};
---

<section id="stack" class="animate-slideIn [animation-delay:90ms]">
  <div class="relative overflow-hidden rounded-2xl border border-ide-border bg-ide-panel/95 p-6 md:p-7">
    <div class="pointer-events-none absolute -right-12 -top-16 h-48 w-48 rounded-full bg-ide-accent/12 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-20 left-6 h-44 w-44 rounded-full bg-ide-purple/10 blur-3xl"></div>
    <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-ide-border to-transparent"></div>

    <div class="relative">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div class="max-w-2xl">
          <h2
            class="text-xl font-semibold text-ide-text md:text-2xl"
            data-i18n-es="Stack Tecnológico"
            data-i18n-en="Technology Stack"
          >
            {t(sectionTitle, lang)}
          </h2>
          <p
            class="mt-2 text-sm text-ide-textMuted"
            data-i18n-es="Tecnologías clave organizadas por dominio para construir productos backend robustos."
            data-i18n-en="Key technologies grouped by domain to build robust backend products."
          >
            {t(sectionCopy, lang)}
          </p>
        </div>
        <div class="flex flex-wrap items-center gap-2 text-[10px] uppercase tracking-[0.2em] text-ide-textMuted">
          <span
            class="rounded-full border border-ide-border bg-ide-bg px-3 py-1"
            data-i18n-es="stack map"
            data-i18n-en="stack map"
          >
            stack map
          </span>
          <span
            class="rounded-full border border-ide-border/80 bg-ide-bg px-3 py-1"
            data-i18n-es={`${stackTecnology.length} dominios`}
            data-i18n-en={`${stackTecnology.length} domains`}
          >
            {t(domainCount, lang)}
          </span>
          <span
            class="rounded-full border border-ide-border/80 bg-ide-bg px-3 py-1"
            data-i18n-es={`${totalItems} tecnologías`}
            data-i18n-en={`${totalItems} technologies`}
          >
            {t(itemCount, lang)}
          </span>
        </div>
      </div>

      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {
          stackTecnology.map((group, index) => (
            <article
              class="card-hover relative overflow-hidden rounded-xl border border-ide-border bg-ide-bg/95 p-4"
              style={`${groupToneStyle(group)} border-color: color-mix(in oklab, var(--tone), var(--ide-border) 70%);`}
            >
              <div class="pointer-events-none absolute -right-6 -top-6 h-20 w-20 rounded-full bg-[color:var(--tone-soft)] blur-2xl"></div>
              <div class="flex items-center justify-between gap-3">
                <div class="flex items-center gap-3">
                  <span
                    class="flex h-9 w-9 items-center justify-center rounded-lg border text-[11px] font-semibold"
                    style="border-color: var(--tone); background: var(--tone-soft); color: var(--tone);"
                  >
                    {String(index + 1).padStart(2, '0')}
                  </span>
                  <div>
                    <h3 class="text-sm font-semibold text-ide-text" data-i18n-es={group.title.es} data-i18n-en={group.title.en}>
                      {t(group.title, lang)}
                    </h3>
                    <p class="text-[11px] text-ide-textMuted">
                      {group.items.length} items
                    </p>
                  </div>
                </div>
                <span
                  class="rounded-full border px-2.5 py-1 text-[10px] uppercase tracking-[0.18em]"
                  style="border-color: var(--tone); background: var(--tone-soft); color: var(--tone);"
                >
                  stack
                </span>
              </div>
              <div class="mt-4 flex flex-wrap gap-2 text-xs">
                {
                  group.items.map((item) => (
                    <span
                      class="rounded-md border px-2.5 py-1 text-ide-text"
                      style="border-color: color-mix(in oklab, var(--tone), transparent 55%); background: color-mix(in oklab, var(--tone), transparent 90%); color: color-mix(in oklab, var(--tone), var(--ide-text) 30%);"
                    >
                      {item}
                    </span>
                  ))
                }
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
