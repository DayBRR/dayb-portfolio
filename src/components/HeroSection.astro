---
import type { FeaturedTechItem, Profile } from '../data/portfolio';
import { toneForTech, toneStyle } from '../data/techTone';
import { t, type Lang } from '../lib/i18n';

interface Props {
  profile: Profile;
  featuredTech: readonly FeaturedTechItem[];
  codeSnippet: readonly string[];
  lang: Lang;
}

const { profile, featuredTech, codeSnippet, lang } = Astro.props;

const activeFeaturedTech = featuredTech.filter((tech) => tech.active).slice(0, 6);

---

<section id="home" class="animate-slideIn">
  <div class="rounded-xl border border-ide-border bg-ide-panel/90 p-5">
    <p class="text-xs uppercase tracking-[0.2em] text-ide-textMuted">backend_profile.ts</p>
    <h1
      class="mt-2 text-2xl font-semibold text-ide-text md:text-4xl"
      data-i18n-es={profile.name}
      data-i18n-en={profile.name}
    >
      {profile.name}
    </h1>
    <p
      class="mt-2 text-sm text-ide-accent md:text-base"
      data-i18n-es={profile.role.es}
      data-i18n-en={profile.role.en}
    >
      {t(profile.role, lang)}
    </p>
    <p
      class="mt-2 text-sm text-ide-textMuted"
      data-i18n-es={profile.location.es}
      data-i18n-en={profile.location.en}
    >
      {t(profile.location, lang)}
    </p>
    <p
      class="mt-1 text-sm text-ide-textMuted"
      data-i18n-es={profile.experience.es}
      data-i18n-en={profile.experience.en}
    >
      {t(profile.experience, lang)}
    </p>
    <p
      class="mt-4 max-w-3xl text-sm text-ide-text md:text-base"
      data-i18n-es={profile.summary.es}
      data-i18n-en={profile.summary.en}
    >
      {t(profile.summary, lang)}
    </p>
    <div class="mt-4 flex flex-wrap gap-2 text-xs">
      <a
        class="rounded-md border border-ide-border bg-ide-bg px-3 py-1 text-ide-text hover:border-ide-accent hover:text-ide-accent"
        href={profile.links.contact.href}
        data-i18n-es={profile.links.contact.es}
        data-i18n-en={profile.links.contact.en}
      >
        {t(profile.links.contact, lang)}
      </a>
      <a
        class="rounded-md border border-ide-border bg-ide-bg px-3 py-1 text-ide-text hover:border-ide-accent hover:text-ide-accent"
        href={profile.links.linkedin.href}
        target="_blank"
        rel="noreferrer"
      >
        {profile.links.linkedin.label}
      </a>
      <a
        class="rounded-md border border-ide-border bg-ide-bg px-3 py-1 text-ide-text hover:border-ide-accent hover:text-ide-accent"
        href={profile.links.github.href}
        target="_blank"
        rel="noreferrer"
      >
        {profile.links.github.label}
      </a>
    </div>

    <div class="mt-5 grid gap-4 lg:grid-cols-[1.35fr_1fr]">
      <div class="rounded-lg border border-ide-border bg-ide-bg p-4">
        <div class="mb-3 flex items-center gap-2 text-xs text-ide-textMuted">
          <span class="rounded border border-ide-border px-2 py-0.5" data-i18n-es="source" data-i18n-en="source">
            source
          </span>
          <span data-i18n-es="preview" data-i18n-en="preview">preview</span>
        </div>
        <div id="typing-code" class="space-y-1 text-sm" data-lines={JSON.stringify(codeSnippet)}>
          {
            codeSnippet.map((_, index) => (
              <div class="flex gap-4">
                <span class="w-5 text-right text-ide-textMuted/80">{index + 1}</span>
                <code class="text-ide-text whitespace-pre-wrap">
                  <span data-code-line={index}></span>
                  <span data-code-caret={index} class="hidden text-ide-accent animate-caret">|</span>
                </code>
              </div>
            ))
          }
          <div class="flex gap-4">
            <span class="w-5 text-right text-ide-textMuted/80">12</span>
            <span id="final-code-caret" class="inline-block text-ide-accent opacity-0">|</span>
          </div>
        </div>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
        {
          activeFeaturedTech.map((tech) => {
            const tone = toneStyle(toneForTech(tech.name));
            return (
              <article
                class="card-hover relative overflow-hidden rounded-lg border bg-ide-bg/95 p-3"
                style={`border-color:${tone.border};box-shadow:${tone.glow};`}
              >
                <span class="absolute left-0 top-0 h-full w-[3px] opacity-70" style={`background:${tone.text};`}></span>
                <div class="pl-2.5">
                  <div class="flex items-start justify-between gap-2">
                    <p class="text-sm font-semibold text-ide-text">{tech.name}</p>
                    <span
                      class="rounded-full border px-1.5 py-0.5 text-[9px] uppercase tracking-[0.15em]"
                      style={`border-color:${tone.border};background:${tone.bg};color:${tone.text};`}
                      data-i18n-es="clave"
                      data-i18n-en="key"
                    >
                      {t({ es: 'clave', en: 'key' }, lang)}
                    </span>
                  </div>
                  <p class="mt-1 text-xs text-ide-textMuted" data-i18n-es={tech.note.es} data-i18n-en={tech.note.en}>
                    {t(tech.note, lang)}
                  </p>
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const typingRoot = document.getElementById('typing-code');

  if (typingRoot instanceof HTMLElement) {
    const rawLines = typingRoot.dataset.lines ?? '[]';
    const lines = JSON.parse(rawLines);
    const lineNodes = Array.from(typingRoot.querySelectorAll('[data-code-line]'));
    const caretNodes = Array.from(typingRoot.querySelectorAll('[data-code-caret]'));
    const finalCaret = document.getElementById('final-code-caret');

    const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

    const setActiveCaret = (activeIndex) => {
      for (const [index, node] of caretNodes.entries()) {
        if (node instanceof HTMLElement) {
          node.classList.toggle('hidden', index !== activeIndex);
        }
      }
    };

    const typeCode = async () => {
      for (const [lineIndex, rawLine] of lines.entries()) {
        const lineText = typeof rawLine === 'string' ? rawLine : '';
        const lineNode = lineNodes[lineIndex];
        if (!(lineNode instanceof HTMLElement)) continue;

        setActiveCaret(lineIndex);
        lineNode.textContent = '';

        for (const character of lineText) {
          lineNode.textContent += character;
          await sleep(24 + Math.floor(Math.random() * 38));
        }

        await sleep(lineText.length > 0 ? 120 : 220);
      }

      for (const caretNode of caretNodes) {
        if (caretNode instanceof HTMLElement) {
          caretNode.classList.add('hidden');
        }
      }

      if (finalCaret instanceof HTMLElement) {
        finalCaret.classList.remove('opacity-0');
        finalCaret.classList.add('animate-caret');
      }
    };

    void typeCode();
  }
</script>
