---
import type { FeaturedTechItem, Profile } from '../data/portfolio';

interface Props {
  profile: Profile;
  featuredTech: readonly FeaturedTechItem[];
  codeSnippet: readonly string[];
}

const { profile, featuredTech, codeSnippet } = Astro.props;

const featuredTone = (tone: FeaturedTechItem['tone']) => {
  const toneMap: Record<string, string> = {
    accent: 'var(--ide-accent)',
    success: 'var(--ide-success)',
    warn: 'var(--ide-warn)',
    info: 'var(--ide-info)',
    danger: 'var(--ide-danger)',
    purple: 'var(--ide-purple)',
    cyan: 'var(--ide-cyan)',
    neutral: 'var(--ide-textMuted)'
  };

  const base = toneMap[tone] ?? 'var(--ide-warn)';

  return {
    border: `color-mix(in oklab, ${base}, var(--ide-border) 60%)`,
    bg: `color-mix(in oklab, ${base}, transparent 90%)`,
    text: base,
    glow: `0 0 0 1px color-mix(in oklab, ${base}, transparent 82%)`
  };
};
---

<section id="home" class="animate-slideIn">
  <div class="rounded-xl border border-ide-border bg-ide-panel/90 p-5">
    <p class="text-xs uppercase tracking-[0.2em] text-ide-textMuted">backend_profile.ts</p>
    <h1 class="mt-2 text-2xl font-semibold text-ide-text md:text-4xl">{profile.name}</h1>
    <p class="mt-2 text-sm text-ide-accent md:text-base">{profile.role}</p>
    <p class="mt-2 text-sm text-ide-textMuted">{profile.location}</p>
    <p class="mt-4 max-w-3xl text-sm text-ide-text md:text-base">{profile.summary}</p>

    <div class="mt-5 grid gap-4 lg:grid-cols-[1.35fr_1fr]">
      <div class="rounded-lg border border-ide-border bg-ide-bg p-4">
        <div class="mb-3 flex items-center gap-2 text-xs text-ide-textMuted">
          <span class="rounded border border-ide-border px-2 py-0.5">source</span>
          <span>preview</span>
        </div>
        <div id="typing-code" class="space-y-1 text-sm" data-lines={JSON.stringify(codeSnippet)}>
          {
            codeSnippet.map((_, index) => (
              <div class="flex gap-4">
                <span class="w-5 text-right text-ide-textMuted/80">{index + 1}</span>
                <code class="text-ide-text whitespace-pre-wrap">
                  <span data-code-line={index}></span>
                  <span data-code-caret={index} class="hidden text-ide-accent animate-caret">|</span>
                </code>
              </div>
            ))
          }
          <div class="flex gap-4">
            <span class="w-5 text-right text-ide-textMuted/80">9</span>
            <span id="final-code-caret" class="inline-block h-4 w-2 animate-caret bg-ide-accent opacity-0"></span>
          </div>
        </div>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
        {
          featuredTech.map((tech) => {
            const tone = featuredTone(tech.tone);
            return (
              <article
                class="card-hover relative overflow-hidden rounded-lg border bg-ide-bg/95 p-3"
                style={`border-color:${tone.border};box-shadow:${tone.glow};`}
              >
                <span class="absolute left-0 top-0 h-full w-[3px] opacity-70" style={`background:${tone.text};`}></span>
                <div class="pl-2.5">
                  <div class="flex items-start justify-between gap-2">
                    <p class="text-sm font-semibold text-ide-text">{tech.name}</p>
                    <span class="rounded-full border px-1.5 py-0.5 text-[9px] uppercase tracking-[0.15em]" style={`border-color:${tone.border};background:${tone.bg};color:${tone.text};`}>
                      key
                    </span>
                  </div>
                  <p class="mt-1 text-xs text-ide-textMuted">{tech.note}</p>
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const typingRoot = document.getElementById('typing-code');

  if (typingRoot instanceof HTMLElement) {
    const rawLines = typingRoot.dataset.lines ?? '[]';
    const lines = JSON.parse(rawLines);
    const lineNodes = Array.from(typingRoot.querySelectorAll('[data-code-line]'));
    const caretNodes = Array.from(typingRoot.querySelectorAll('[data-code-caret]'));
    const finalCaret = document.getElementById('final-code-caret');

    const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

    const setActiveCaret = (activeIndex) => {
      for (const [index, node] of caretNodes.entries()) {
        if (node instanceof HTMLElement) {
          node.classList.toggle('hidden', index !== activeIndex);
        }
      }
    };

    const typeCode = async () => {
      for (const [lineIndex, rawLine] of lines.entries()) {
        const lineText = typeof rawLine === 'string' ? rawLine : '';
        const lineNode = lineNodes[lineIndex];
        if (!(lineNode instanceof HTMLElement)) continue;

        setActiveCaret(lineIndex);
        lineNode.textContent = '';

        for (const character of lineText) {
          lineNode.textContent += character;
          await sleep(24 + Math.floor(Math.random() * 38));
        }

        await sleep(lineText.length > 0 ? 120 : 220);
      }

      for (const caretNode of caretNodes) {
        if (caretNode instanceof HTMLElement) {
          caretNode.classList.add('hidden');
        }
      }

      if (finalCaret instanceof HTMLElement) {
        finalCaret.classList.remove('opacity-0');
      }
    };

    void typeCode();
  }
</script>
