---
import type { ProjectItem } from '../data/portfolio';

interface Props {
  projects: readonly ProjectItem[];
}

const { projects } = Astro.props;

const stackToneStyle = (tech: string) => {
  const normalized = tech.toLowerCase();
  if (
    normalized.includes('node') ||
    normalized.includes('nest') ||
    normalized.includes('type') ||
    normalized.includes('javascript') ||
    normalized.includes('fastify') ||
    normalized.includes('express')
  ) {
    return {
      border: 'var(--ide-accent)',
      bg: 'var(--ide-accent-soft)',
      text: 'var(--ide-accent)'
    };
  }

  if (
    normalized.includes('postgres') ||
    normalized.includes('mongo') ||
    normalized.includes('redis') ||
    normalized.includes('kafka') ||
    normalized.includes('rabbit') ||
    normalized.includes('sql')
  ) {
    return {
      border: 'color-mix(in oklab, var(--ide-success), transparent 35%)',
      bg: 'color-mix(in oklab, var(--ide-success), transparent 84%)',
      text: 'var(--ide-success)'
    };
  }

  return {
    border: 'color-mix(in oklab, var(--ide-warn), transparent 35%)',
    bg: 'color-mix(in oklab, var(--ide-warn), transparent 84%)',
    text: 'var(--ide-warn)'
  };
};
---

<section id="projects" class="animate-slideIn [animation-delay:120ms]">
  <div class="rounded-xl border border-ide-border bg-ide-panel/90 p-5">
    <h2 class="text-xl font-semibold text-ide-text md:text-2xl">Proyectos Destacados</h2>
    <p class="mt-2 text-sm text-ide-textMuted">Haz click en cualquier parte de la tarjeta para abrir su modal con detalles, repositorio y demo.</p>
    <div class="mt-5 grid gap-4 md:grid-cols-2">
      {
        projects.map((project) => (
          <button
            type="button"
            class="project-card-trigger open-project-modal card-hover w-full rounded-lg border border-ide-border bg-ide-bg p-4 text-left hover:border-ide-accent hover:shadow-glow focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ide-accent focus-visible:ring-offset-2 focus-visible:ring-offset-ide-panel"
            data-title={project.title}
            data-summary={project.summary}
            data-description={project.description}
            data-repo={project.repo}
            data-demo={project.demo}
            data-stack={project.stack.join(' | ')}
            aria-label={`Abrir detalles del proyecto ${project.title}`}
          >
            <p class="text-lg font-semibold text-ide-text">{project.title}</p>
            <p class="mt-2 text-sm text-ide-textMuted">{project.summary}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {
                project.stack.map((tech) => {
                  const tone = stackToneStyle(tech);
                  return (
                    <span
                      class="rounded-md border px-2.5 py-1 text-[11px] font-semibold tracking-wide"
                      style={`border-color:${tone.border};background:${tone.bg};color:${tone.text};`}
                    >
                      {tech}
                    </span>
                  );
                })
              }
            </div>
            <p class="mt-4 text-[11px] uppercase tracking-[0.18em] text-ide-accent">click to inspect</p>
          </button>
        ))
      }
    </div>
  </div>
</section>
