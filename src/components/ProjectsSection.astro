---
import type { ProjectItem } from '../data/portfolio';
import { getStatusMeta } from '../data/projectStatus';
import { toneForTech, toneStyle } from '../data/techTone';

interface Props {
  projects: readonly ProjectItem[];
}

const { projects } = Astro.props;

---

<section id="projects" class="animate-slideIn [animation-delay:120ms]">
  <div class="rounded-xl border border-ide-border bg-ide-panel/90 p-5">
    <h2
      class="text-xl font-semibold text-ide-text md:text-2xl"
      data-i18n-es="Proyectos Destacados"
      data-i18n-en="Featured Projects"
    >
      Proyectos Destacados
    </h2>
    <p
      class="mt-2 text-sm text-ide-textMuted"
      data-i18n-es="Haz click en cualquier parte de la tarjeta para abrir su modal con detalles y enlaces disponibles."
      data-i18n-en="Click anywhere on a card to open the modal with details and available links."
    >
      Haz click en cualquier parte de la tarjeta para abrir su modal con detalles y enlaces disponibles.
    </p>
    <div class="mt-5 grid gap-4 md:grid-cols-2">
      {
        projects.map((project) => {
          const statusMeta = getStatusMeta(project.status);
          const statusEs = statusMeta.label.es;
          const statusEn = statusMeta.label.en;
          const statusStyle = `border-color:${statusMeta.color};color:${statusMeta.color};background:${statusMeta.bg};`;
          const hasStatus = statusEs.length > 0 || statusEn.length > 0;
          return (
            <button
              type="button"
              class="project-card-trigger open-project-modal card-hover w-full rounded-lg border border-ide-border bg-ide-bg p-4 text-left hover:border-ide-accent hover:shadow-glow focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ide-accent focus-visible:ring-offset-2 focus-visible:ring-offset-ide-panel"
              data-title={project.title}
              data-summary-es={project.summary.es}
              data-summary-en={project.summary.en}
              data-description-es={project.description.es}
              data-description-en={project.description.en}
              data-status={project.status}
              data-repo={project.repo}
              data-demo={project.demo}
              data-stack={project.stack.join(' | ')}
              aria-label={`Abrir detalles del proyecto ${project.title}`}
              data-i18n-attr="aria-label"
              data-i18n-es={`Abrir detalles del proyecto ${project.title}`}
              data-i18n-en={`Open project details for ${project.title}`}
            >
              <div class="flex flex-wrap items-center justify-between gap-2">
                <p class="text-lg font-semibold text-ide-text">{project.title}</p>
                {
                  hasStatus ? (
                    <span
                      class="inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.2em]"
                      style={statusStyle}
                    >
                      <span class="inline-flex h-3 w-3" set:html={statusMeta.icon}></span>
                      <span data-i18n-es={statusEs} data-i18n-en={statusEn}>
                        {statusEs}
                      </span>
                    </span>
                  ) : null
                }
              </div>
              <p class="mt-2 text-sm text-ide-textMuted" data-i18n-es={project.summary.es} data-i18n-en={project.summary.en}>
                {project.summary.es}
              </p>
              <div class="mt-3 flex flex-wrap gap-2">
                {
                  project.stack.map((tech) => {
                    const tone = toneStyle(toneForTech(tech));
                    return (
                      <span
                        class="rounded-md border px-2.5 py-1 text-[11px] font-semibold tracking-wide"
                        style={`border-color:${tone.border};background:${tone.bg};color:${tone.text};`}
                      >
                        {tech}
                      </span>
                    );
                  })
                }
              </div>
              <p class="mt-4 text-[11px] uppercase tracking-[0.18em] text-ide-accent" data-i18n-es="click para inspeccionar" data-i18n-en="click to inspect">
                click para inspeccionar
              </p>
            </button>
          );
        })
      }
    </div>
  </div>
</section>
