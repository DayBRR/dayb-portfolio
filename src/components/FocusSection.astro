---
import type { FocusHighlight } from '../data/portfolio';
import { t, type Lang } from '../lib/i18n';

interface Props {
  highlights: readonly FocusHighlight[];
  lang: Lang;
}

const { highlights, lang } = Astro.props;

const showFocusMap = true;
const focusIntro = {
  es: 'Este mapa muestra los criterios que guían mis decisiones al diseñar sistemas backend en entornos reales de producción.',
  en: 'This map reflects the criteria that guide my decisions when designing backend systems in real production environments.'
};
const focusTitle = { es: 'Matriz de Enfoque', en: 'Focus Matrix' };
const focusSummary = {
  es: 'Representación visual de las prioridades que guían mis decisiones de ingeniería de software.',
  en: 'Visual representation of the priorities that guide my software engineering decisions.'
};
const focusDisclaimer = {
  es: 'NO REPRESENTAN NIVEL DE DOMINIO, SINO PESO RELATIVO EN EL ENFOQUE.',
  en: 'NOT A SKILL RATING, BUT RELATIVE WEIGHT IN MY APPROACH.'
};
const focusBadge = { es: 'prioridades', en: 'priorities' };

const iconPaths = {
  layers: ['M12 3l8 4-8 4-8-4 8-4z', 'M4 11l8 4 8-4', 'M4 15l8 4 8-4'],
  metrics: ['M4 18V10', 'M10 18V6', 'M16 18V13', 'M3 18h18'],
  lock: ['M7 10h10a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-6a2 2 0 0 1 2-2z', 'M9 10V8a3 3 0 0 1 6 0v2'],
  scale: ['M12 4v16', 'M6 8l6-4 6 4', 'M6 16l6 4 6-4'],
  bolt: ['M13 2L4 14h6l-1 8 9-12h-6l1-8z']
} as const;

const mapPool = [
  {
    name: { es: 'Arquitectura', en: 'Architecture' },
    value: 95,
    tone: 'accent',
    icon: 'layers',
    detail: {
      es: 'Base de todas las decisiones técnicas: diseño orientado a dominio, separación de responsabilidades y mantenibilidad a largo plazo.',
      en: 'Foundation for technical decisions: domain-driven design, clear boundaries, and long-term maintainability.'
    }
  },
  {
    name: { es: 'Observabilidad', en: 'Observability' },
    value: 90,
    tone: 'success',
    icon: 'metrics',
    detail: {
      es: 'Diseño de sistemas preparados para producción con logging estructurado, métricas, trazabilidad, monitorización y alertado.',
      en: 'Production-ready systems with structured logging, metrics, tracing, monitoring and alerting.'
    }
  },
  {
    name: { es: 'Seguridad & Compliance', en: 'Security & Compliance' },
    value: 88,
    tone: 'purple',
    icon: 'lock',
    detail: {
      es: 'Protección de datos sensibles, cumplimiento normativo e integraciones seguras en entornos críticos.',
      en: 'Sensitive data protection, regulatory compliance, and secure integrations in critical environments.'
    }
  },
  {
    name: { es: 'Escalabilidad & Resiliencia', en: 'Scalability & Resilience' },
    value: 85,
    tone: 'info',
    icon: 'scale',
    detail: {
      es: 'Capacidad para diseñar sistemas tolerantes a fallos, con crecimiento sostenido y degradación controlada del sistema.',
      en: 'Designing fault-tolerant systems with sustained growth and controlled degradation.'
    }
  },
  {
    name: { es: 'Performance', en: 'Performance' },
    value: 80,
    tone: 'warn',
    icon: 'bolt',
    detail: {
      es: 'Optimización selectiva mediante tuning de consultas, procesos batch, uso eficiente de recursos y reducción de latencias.',
      en: 'Selective optimization via query tuning, batch processing, efficient resource usage and latency reduction.'
    }
  }
] as const;

const mapToneStyle = (tone: string) => `--tone: var(--ide-${tone});`;

const groupToneStyle = (index: number) => {
  if (index % 2 === 0) {
    return '--tone: var(--ide-accent); --tone-soft: var(--ide-accent-soft);';
  }
  return '--tone: var(--ide-success); --tone-soft: color-mix(in oklab, var(--ide-success), transparent 84%);';
};
---

<section id="focus" class="animate-slideIn [animation-delay:40ms]">
  <div class="relative overflow-hidden rounded-xl border border-ide-border bg-ide-panel/95 p-5 md:p-6">
    <div class="pointer-events-none absolute -right-14 -top-16 h-40 w-40 rounded-full bg-ide-accent/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-16 left-10 h-32 w-32 rounded-full bg-ide-success/10 blur-3xl"></div>
    <div class="grid gap-4 md:grid-cols-2">
      {
        highlights.map((highlight, index) => (
          <article
            class="card-hover relative overflow-hidden rounded-xl border border-ide-border bg-ide-bg/95 p-4"
            style={`${groupToneStyle(index)} border-color: color-mix(in oklab, var(--tone), var(--ide-border) 70%);`}
          >
            <div class="pointer-events-none absolute -right-6 -top-8 h-20 w-20 rounded-full bg-[color:var(--tone-soft)] blur-2xl"></div>
            <div class="flex items-start gap-3">
              <span class="mt-1 h-10 w-1 rounded-full" style="background: var(--tone);"></span>
              <div>
                <h2
                  class="text-sm font-semibold uppercase tracking-[0.2em] text-ide-text"
                  data-i18n-es={highlight.title.es}
                  data-i18n-en={highlight.title.en}
                >
                  {t(highlight.title, lang)}
                </h2>
                <ul class="mt-3 space-y-2 text-sm text-ide-text">
                  {
                    highlight.items.map((item) => (
                      <li class="flex items-start gap-2">
                        <span class="mt-1.5 h-1.5 w-1.5 flex-none rounded-full" style="background: var(--tone);"></span>
                        <span data-i18n-es={item.es} data-i18n-en={item.en}>
                          {t(item, lang)}
                        </span>
                      </li>
                    ))
                  }
                </ul>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    {
      showFocusMap && (
        <div class="mt-5 rounded-xl border border-ide-border bg-ide-bg/95 p-4">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <p
                class="text-xs text-ide-textMuted"
                data-i18n-es="Este mapa muestra los criterios que guían mis decisiones al diseñar sistemas backend en entornos reales de producción."
                data-i18n-en="This map reflects the criteria that guide my decisions when designing backend systems in real production environments."
              >
                {t(focusIntro, lang)}
              </p>
              <h2
                class="mt-2 text-base font-semibold uppercase tracking-[0.2em] text-ide-text"
                data-i18n-es="Matriz de Enfoque"
                data-i18n-en="Focus Matrix"
              >
                {t(focusTitle, lang)}
              </h2>
              <p
                class="mt-2 text-xs text-ide-textMuted"
                data-i18n-es="Representación visual de las prioridades que guían mis decisiones de ingeniería de software."
                data-i18n-en="Visual representation of the priorities that guide my software engineering decisions."
              >
                {t(focusSummary, lang)}
              </p>
              <p
                class="mt-2 text-[11px] uppercase tracking-[0.22em] text-ide-textMuted/80"
                data-i18n-es="NO REPRESENTAN NIVEL DE DOMINIO, SINO PESO RELATIVO EN EL ENFOQUE."
                data-i18n-en="NOT A SKILL RATING, BUT RELATIVE WEIGHT IN MY APPROACH."
              >
                {t(focusDisclaimer, lang)}
              </p>
            </div>
            <div
              class="rounded-full border border-ide-border bg-ide-panel-soft px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-ide-textMuted"
              data-i18n-es="prioridades"
              data-i18n-en="priorities"
            >
              {t(focusBadge, lang)}
            </div>
          </div>
          <div class="mt-4 grid gap-3 md:grid-cols-2">
            {
              mapPool.map((map, index) => {
                const isPrimary = index === 0;
                const barHeight = isPrimary ? '10px' : '8px';
                return (
                <div>
                  <div class="flex items-center gap-3">
                  <span
                    class="flex h-10 w-10 items-center justify-center rounded-lg border border-ide-border bg-ide-panel-soft text-ide-text"
                    style={`${mapToneStyle(map.tone)} border-color: color-mix(in oklab, var(--tone), var(--ide-border) 55%); color: color-mix(in oklab, var(--tone), var(--ide-text) 25%);`}
                  >
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      {
                        iconPaths[map.icon].map((path) => (
                          <path
                            d={path}
                            stroke="currentColor"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          />
                        ))
                      }
                    </svg>
                  </span>
                  <div class="flex-1">
                    <div class="flex items-center justify-between text-[11px] text-ide-textMuted">
                      <span data-i18n-es={map.name.es} data-i18n-en={map.name.en}>
                        {t(map.name, lang)}
                      </span>
                      <span class="text-ide-text">{map.value}%</span>
                    </div>
                    <div class="mt-1.5 rounded-full bg-ide-panel-soft" style={`height: ${barHeight};`}>
                      <div
                        class="rounded-full"
                        style={`${mapToneStyle(map.tone)} width: ${map.value}%; height: ${barHeight}; background: color-mix(in oklab, var(--tone), transparent 10%); ${isPrimary ? 'box-shadow: 0 0 12px color-mix(in oklab, var(--tone), transparent 60%);' : ''}`}
                      ></div>
                    </div>
                  </div>
                  </div>
                  <p class="mt-2 text-[11px] text-ide-textMuted" data-i18n-es={map.detail.es} data-i18n-en={map.detail.en}>
                    {t(map.detail, lang)}
                  </p>
                </div>
                );
              })
            }
          </div>
        </div>
      )
    }
  </div>
</section>
