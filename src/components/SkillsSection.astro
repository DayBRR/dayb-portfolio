---
import type { SkillGroup } from '../data/portfolio';

interface Props {
  skills: readonly SkillGroup[];
}

const { skills } = Astro.props;

const groupToneStyle = (group: SkillGroup) => {
  const haystack = `${group.title.es} ${group.title.en}`.toLowerCase();
  if (haystack.includes('calidad') || haystack.includes('quality') || haystack.includes('seguridad') || haystack.includes('security')) {
    return '--tone: var(--ide-purple); --tone-soft: color-mix(in oklab, var(--ide-purple), transparent 84%);';
  }
  if (haystack.includes('data') || haystack.includes('datos')) {
    return '--tone: var(--ide-success); --tone-soft: color-mix(in oklab, var(--ide-success), transparent 84%);';
  }
  if (haystack.includes('devops') || haystack.includes('cloud')) {
    return '--tone: var(--ide-warn); --tone-soft: color-mix(in oklab, var(--ide-warn), transparent 84%);';
  }
  return '--tone: var(--ide-accent); --tone-soft: var(--ide-accent-soft);';
};
---

<section id="skills" class="animate-slideIn [animation-delay:70ms]">
  <div class="rounded-xl border border-ide-border bg-ide-panel/90 p-5">
    <h2
      class="text-xl font-semibold text-ide-text md:text-2xl"
      data-i18n-es="Skills & Tecnologías"
      data-i18n-en="Skills & Technologies"
    >
      Skills & Tecnologías
    </h2>
    <p
      class="mt-2 text-sm text-ide-textMuted"
      data-i18n-es="Capacidades principales orientadas a productos backend de alta exigencia."
      data-i18n-en="Core capabilities focused on high-demand backend products."
    >
      Capacidades principales orientadas a productos backend de alta exigencia.
    </p>
    <div class="mt-5 grid gap-4 md:grid-cols-2">
      {
        skills.map((group) => (
          <article
            class="rounded-lg border border-ide-border bg-ide-bg p-4"
            style={`${groupToneStyle(group)} border-color: color-mix(in oklab, var(--tone), var(--ide-border) 70%);`}
          >
            <div class="mb-3 flex items-center justify-between gap-2">
              <h3 class="text-sm font-semibold text-ide-text" data-i18n-es={group.title.es} data-i18n-en={group.title.en}>
                {group.title.es}
              </h3>
              <span
                class="rounded-full border px-2 py-0.5 text-[10px] uppercase tracking-[0.18em]"
                style="border-color: var(--tone); background: var(--tone-soft); color: var(--tone);"
              >
                stack
              </span>
            </div>
            <div class="mt-3 flex flex-wrap gap-2">
              {
                group.items.map((item) => (
                  <span
                    class="rounded-md border px-2.5 py-1 text-xs font-semibold text-ide-text"
                    style="border-color: color-mix(in oklab, var(--tone), transparent 55%); background: color-mix(in oklab, var(--tone), transparent 90%); color: color-mix(in oklab, var(--tone), var(--ide-text) 30%);"
                  >
                    {item}
                  </span>
                ))
              }
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
