---
import type { SkillGroup } from '../data/portfolio';

interface Props {
  skills: readonly SkillGroup[];
}

const { skills } = Astro.props;

const groupToneStyle = (index: number) => {
  if (index % 3 === 0) {
    return 'border-color:var(--ide-accent);background:var(--ide-accent-soft);color:var(--ide-accent);';
  }
  if (index % 3 === 1) {
    return 'border-color:color-mix(in oklab, var(--ide-success), transparent 35%);background:color-mix(in oklab, var(--ide-success), transparent 84%);color:var(--ide-success);';
  }
  return 'border-color:color-mix(in oklab, var(--ide-warn), transparent 35%);background:color-mix(in oklab, var(--ide-warn), transparent 84%);color:var(--ide-warn);';
};
---

<section id="skills" class="animate-slideIn [animation-delay:70ms]">
  <div class="rounded-xl border border-ide-border bg-ide-panel/90 p-5">
    <h2
      class="text-xl font-semibold text-ide-text md:text-2xl"
      data-i18n-es="Skills & Tecnologías"
      data-i18n-en="Skills & Technologies"
    >
      Skills & Tecnologías
    </h2>
    <p
      class="mt-2 text-sm text-ide-textMuted"
      data-i18n-es="Capacidades principales orientadas a productos backend de alta exigencia."
      data-i18n-en="Core capabilities focused on high-demand backend products."
    >
      Capacidades principales orientadas a productos backend de alta exigencia.
    </p>
    <div class="mt-5 grid gap-4 md:grid-cols-2">
      {
        skills.map((group, index) => (
          <article class="rounded-lg border border-ide-border bg-ide-bg p-4">
            <div class="mb-3 flex items-center justify-between gap-2">
              <h3 class="text-sm font-semibold text-ide-text" data-i18n-es={group.title.es} data-i18n-en={group.title.en}>
                {group.title.es}
              </h3>
              <span class="rounded-full border px-2 py-0.5 text-[10px] uppercase tracking-[0.18em]" style={groupToneStyle(index)}>stack</span>
            </div>
            <div class="mt-3 flex flex-wrap gap-2">
              {
                group.items.map((item) => (
                  <span class="rounded-md border border-ide-border bg-ide-panel-soft px-2.5 py-1 text-xs font-semibold text-ide-text">
                    {item}
                  </span>
                ))
              }
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
